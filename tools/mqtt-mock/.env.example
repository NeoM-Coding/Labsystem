MQTT_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=lab-system-mqtt-mock
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic subscribed by the mock device. "*" is accepted and normalized to MQTT "+".
MQTT_SUBSCRIBE_TOPIC=test/accept/+

# Used when MQTT_TOPIC_REGEX is empty or does not match.
MQTT_REPLY_TOPIC=test/send

# Optional topic decoder. Named groups can be used by MQTT_REPLY_TOPIC_TEMPLATE.
# Example:
# MQTT_TOPIC_REGEX=^gateway/(?<gatewayId>[^/]+)/accept$
# MQTT_REPLY_TOPIC_TEMPLATE=gateway/${gatewayId}/send
MQTT_TOPIC_REGEX=^test/accept/(?<topicKey>[^/]+)$
MQTT_REPLY_TOPIC_TEMPLATE=test/send/${topicKey}

MQTT_QOS=0
